{
  "uid": "pi5-power",
  "title": "Pi 5 power & throttling",
  "tags": ["homelab", "pi5", "power"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Under-voltage & throttling (current state)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Under-voltage NOW",
      "description": "vcgencmd get_throttled bit 0. If this is ever 1 your PSU/cable is dipping right now.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max(pi5_throttled{flag=\"undervoltage_now\"})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "UNDER-VOLT", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Under-voltage since boot",
      "description": "vcgencmd get_throttled bit 16. Sticky flag. Any 1 here means at least one dip happened since boot.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max(pi5_throttled{flag=\"undervoltage_since_boot\"})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Clean", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Seen", "color": "orange" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Throttling NOW",
      "description": "vcgencmd get_throttled bit 2.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max(pi5_throttled{flag=\"throttled_now\"})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "THROTTLED", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Exporter healthy",
      "description": "0 = vcgencmd missing or last run failed.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max(pi5_power_exporter_up)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Throttle bits over time",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "state-timeline",
      "title": "Throttle / under-voltage state timeline",
      "description": "Each row is one decoded bit from vcgencmd get_throttled. Red = condition active.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pi5_throttled",
          "legendFormat": "{{flag}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "ok" } } },
            { "type": "value", "options": { "1": { "text": "set" } } }
          ]
        }
      },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "alignValue": "left"
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "PMIC rail voltages",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "type": "stat",
      "title": "EXT5V (board input rail)",
      "description": "Voltage delivered onto the board after the USB-C input. Healthy ~5.0–5.15 V; below ~4.8 V usually means PSU/cable cannot keep up.",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pi5_pmic_volts{rail=\"EXT5V_V\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 4.75 },
              { "color": "green", "value": 4.9 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "VDD_CORE (SoC core)",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pi5_pmic_volts{rail=\"VDD_CORE_V\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 3
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "3V3 system rail",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pi5_pmic_volts{rail=\"3V3_SYS_V\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 3
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "All PMIC voltage rails",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pi5_pmic_volts",
          "legendFormat": "{{rail}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "PMIC rail currents",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "stat",
      "title": "VDD_CORE current",
      "description": "Real-time SoC core current draw. Spikes here cause EXT5V to sag on a weak PSU/cable.",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pi5_pmic_current_amps{rail=\"VDD_CORE_A\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "3V3 system current",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pi5_pmic_current_amps{rail=\"3V3_SYS_A\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Peak rail current (15 m)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max(max_over_time(pi5_pmic_current_amps[15m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "All PMIC current rails",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pi5_pmic_current_amps",
          "legendFormat": "{{rail}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 104,
      "type": "row",
      "title": "Firmware-reported rails (vcgencmd measure_volts)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Core / SDRAM rails",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pi5_measure_volts",
          "legendFormat": "{{rail}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    }
  ]
}
